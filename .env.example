# Required: get from https://discord.com/developers/applications -> your app -> Bot -> Reset Token
DISCORD_TOKEN=your_discord_bot_token_here

# Optional: command prefix (default: $)
COMMAND_PREFIX=$

# Optional: SQLite database file
DATABASE_PATH=data/bot.db

# Optional: how often (seconds) the alerts task scans prices
ALERT_CHECK_INTERVAL_SECONDS=300

# Optional: AI provider for $summary. Set ONE of these.
# Get a Gemini key at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=
# Get an OpenAI key at https://platform.openai.com/api-keys
OPENAI_API_KEY=
